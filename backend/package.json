{
  "name": "search-typeahead-backend",
  "version": "1.0.0",
  "description": "Backend for the search typeahead system: trie suggestions, consistent-hashing cache, batch writes, trending.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "ingest": "tsx scripts/ingest.ts",
    "redis:up": "bash scripts/redis-local.sh up",
    "redis:down": "bash scripts/redis-local.sh down",
    "bench": "tsx scripts/bench.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
